# Web Application Configuration

# REST API Base URL
VITE_API_BASE_URL=http://localhost:8080/api/v1

# WebSocket Base URL
VITE_WS_BASE_URL=ws://localhost:8080

# Grafana Dashboard URL (For Admin Panel)
VITE_GRAFANA_URL=http://localhost:3001

# Mock API (optional)
# To develop with mocked API responses (no backend required), run: pnpm dev:mock
# This loads .env.mock instead and enables MSW (Mock Service Worker)
# VITE_ENABLE_MOCK_API=true
