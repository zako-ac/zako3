# Mock API Development Mode
# Run: pnpm dev:mock

# Enable MSW and use relative API paths so service worker (same origin) intercepts all calls
VITE_ENABLE_MOCK_API=true
VITE_API_BASE_URL=/api/v1

# WebSocket and other config (not critical for mock API, but complete for consistency)
VITE_WS_BASE_URL=ws://localhost
VITE_GRAFANA_URL=http://localhost:3001
