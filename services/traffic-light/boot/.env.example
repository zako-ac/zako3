# Optional: OTLP tracing endpoint (e.g., "http://jaeger:4318/v1/traces")
# OTLP_ENDPOINT=http://localhost:4318/v1/traces

# Optional: Prometheus metrics port
# METRICS_PORT=9090

# Optional: tarpc API listener address
# TARPC_ADDR=0.0.0.0:7070

# Optional: AE transport listener address
# AE_TRANSPORT_ADDR=0.0.0.0:7071

# Required: Comma-separated Discord bot tokens
# DISCORD_TOKENS=token1,token2,token3

