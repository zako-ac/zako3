ZK_TH_TRANSPORT_BIND_ADDR=0.0.0.0:4000
ZK_TH_ZAKOFISH_BIND_ADDR=0.0.0.0:4001
# Optional. When set, the Hub also accepts pf3 (protofish3) tap connections on
# this address, sharing the same cert/key as the pf2 port above.
# ZK_TH_ZAKOFISH_BIND_ADDR_PF3=0.0.0.0:4002

ZK_TH_HQ_RPC_URL=http://localhost:50051
ZK_TH_HQ_RPC_ADMIN_TOKEN=sdfgfdsg

ZK_TH_ZAKOFISH_CERT_FILE=zakofish-cert.pem
ZK_TH_ZAKOFISH_KEY_FILE=zakofish-key.pem
ZK_TH_TAPHUB_TRANSPORT_CERT_FILE=transport-cert.pem
ZK_TH_TAPHUB_TRANSPORT_KEY_FILE=transport-key.pem

ZK_TH_REDIS_URL=redis://localhost::6379

ZK_TH_CACHE_RPC_URL=http://localhost:4100
# Optional. If the cache server enforces ZK_CACHE_ADMIN_TOKEN, this must match.
ZK_TH_CACHE_RPC_ADMIN_TOKEN=

ZK_TH_REQUEST_TIMEOUT_MS=13000

# Telemetry (optional)
ZK_TH_OTLP_ENDPOINT=http://localhost:5081
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64>,organization=default,stream-name=default
# OTEL_FILTER=debug,h2=off,tonic=off,hyper=off,tower=off,quinn=off,jsonrpsee=off,serenity::gateway=off
ZK_TH_METRICS_PORT=9092
