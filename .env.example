# =============================================================================
# Zako3 Docker Compose Environment
# Copy to .env and fill in all required values before running docker compose up
# =============================================================================

# -----------------------------------------------------------------------------
# Infrastructure — PostgreSQL (used by hq)
# -----------------------------------------------------------------------------
POSTGRES_USER=zako3
POSTGRES_PASSWORD=changeme
POSTGRES_DB=zako3

# -----------------------------------------------------------------------------
# Infrastructure — TimescaleDB (used by metrics-sync)
# -----------------------------------------------------------------------------
TIMESCALE_USER=metrics
TIMESCALE_PASSWORD=changeme
TIMESCALE_DB=metrics

# -----------------------------------------------------------------------------
# audio-engine
# -----------------------------------------------------------------------------
AUDIO_DISCORD_TOKEN=
AUDIO_AE_TOKEN=changeme

# -----------------------------------------------------------------------------
# hq
# -----------------------------------------------------------------------------
HQ_RPC_ADMIN_TOKEN=changeme

HQ_DISCORD_CLIENT_ID=
HQ_DISCORD_CLIENT_SECRET=
HQ_DISCORD_REDIRECT_URI=http://localhost:8080/auth/callback
HQ_DISCORD_BOT_TOKEN=

HQ_JWT_SECRET=changeme

# -----------------------------------------------------------------------------
# taphub
# -----------------------------------------------------------------------------
# Must match HQ_RPC_ADMIN_TOKEN
ZK_TH_HQ_RPC_ADMIN_TOKEN=changeme

# Paths to TLS certificate and key (mount into the container as needed)
ZK_TH_CERT_FILE=cert.pem
ZK_TH_KEY_FILE=key.pem

# -----------------------------------------------------------------------------
# cache-gc
# -----------------------------------------------------------------------------
CACHE_GC_CACHE_DIR=/cache
# Maximum total cache size (bytes). Example: 10737418240 = 10 GiB
CACHE_GC_MAX_BYTES=

# -----------------------------------------------------------------------------
# metrics-sync
# -----------------------------------------------------------------------------
METRICS_SYNC_INTERVAL_SECONDS=60
